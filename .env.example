# --- Supabase ---
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."
# Server-side only (NEVER expose to the browser). Used for admin operations.
SUPABASE_SERVICE_ROLE_KEY="ey..."

# Used by `npm run db:gen-types`
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Creative Wings"

# --- Email ---
# Required for app-level email verification.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Creative Wings <hello@creativewings.my>"

# --- Optional integrations (wire up later) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
